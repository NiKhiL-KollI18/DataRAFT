<CPackWiXPatch>
    <CPackWiXFragment Id="#PRODUCT">

        <DirectoryRef Id="TARGETDIR">
            <Component Id="CMakePath" Guid="B8A04898-132A-4D78-9B1D-6F4E85DE741D">

                <RegistryValue Root="HKCU" Key="Software\DataRAFT" Name="PathInjected" Type="integer" Value="1" KeyPath="yes"/>

                <Environment Id="PATH" Name="PATH" Value="[INSTALL_ROOT]bin"
                             Separator=";" Action="set" Part="last" System="yes" />

            </Component>
        </DirectoryRef>

        <Feature Id="PathFeature" Title="System PATH Update" Level="1">
            <ComponentRef Id="CMakePath" />
        </Feature>

        <Property
                Id="WIXUI_EXITDIALOGOPTIONALTEXT"
                Value="Welcome to the DataRAFT Engine!&#13;&#10;Get started by typing: raft --help in a terminal&#13;&#10;Defaults download to your &quot;Downloads&quot; folder&#13;&#10;Change using: raft set default_download_dir &lt;path&gt;" />

    </CPackWiXFragment>
</CPackWiXPatch>